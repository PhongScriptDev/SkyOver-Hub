local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")

local gui = Instance.new("ScreenGui")
gui.Parent = player.PlayerGui

-- Nút tròn mở menu
local toggle = Instance.new("TextButton")
toggle.Parent = gui
toggle.Size = UDim2.new(0,60,0,60)
toggle.Position = UDim2.new(0,50,0,200)
toggle.Text = "MENU"
toggle.BackgroundColor3 = Color3.fromRGB(0,0,0)
toggle.TextColor3 = Color3.fromRGB(255,0,0)
toggle.Active = true
toggle.Draggable = true

local corner = Instance.new("UICorner",toggle)
corner.CornerRadius = UDim.new(1,0)

-- Frame menu
local frame = Instance.new("Frame")
frame.Parent = gui
frame.Size = UDim2.new(0,220,0,200)
frame.Position = UDim2.new(0,120,0,200)
frame.BackgroundColor3 = Color3.fromRGB(0,0,0)
frame.BorderColor3 = Color3.fromRGB(255,0,0)
frame.Visible = false
frame.Active = true
frame.Draggable = true

toggle.MouseButton1Click:Connect(function()
	frame.Visible = not frame.Visible
end)

-- Speed box
local speed = Instance.new("TextBox",frame)
speed.Size = UDim2.new(0,200,0,30)
speed.Position = UDim2.new(0,10,0,10)
speed.PlaceholderText = "Speed 20-1000"

speed.FocusLost:Connect(function()
	local v = tonumber(speed.Text)
	if v and v >= 20 and v <= 1000 then
		hum.WalkSpeed = v
	end
end)

-- Jump box
local jump = Instance.new("TextBox",frame)
jump.Size = UDim2.new(0,200,0,30)
jump.Position = UDim2.new(0,10,0,50)
jump.PlaceholderText = "Jump 35-1000"

jump.FocusLost:Connect(function()
	local v = tonumber(jump.Text)
	if v and v >= 35 and v <= 1000 then
		hum.JumpPower = v
	end
end)

-- Infinite Jump
local inf = false

local infBtn = Instance.new("TextButton",frame)
infBtn.Size = UDim2.new(0,200,0,30)
infBtn.Position = UDim2.new(0,10,0,90)
infBtn.Text = "Infinite Jump OFF"

infBtn.MouseButton1Click:Connect(function()
	inf = not inf
	infBtn.Text = inf and "Infinite Jump ON" or "Infinite Jump OFF"
end)

game:GetService("UserInputService").JumpRequest:Connect(function()
	if inf then
		hum:ChangeState(Enum.HumanoidStateType.Jumping)
	end
end)
